{
  "id": "markdown-notes",
  "name": "Markdown Notes",
  "version": "2.0.0",
  "minNoctaliaVersion": "3.7.1",
  "author": "fusuyfusuy",
  "license": "MIT",
  "repository": "https://github.com/noctalia-dev/noctalia-plugins",
  "description": "A note taking plugin for Noctalia Shell. Reads and writes .md files from a configurable folder.",
  "tags": ["Bar", "Panel", "Productivity"],
  "entryPoints": {
    "main": "Main.qml",
    "barWidget": "BarWidget.qml",
    "panel": "Panel.qml",
    "settings": "Settings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "vaultPath": "~/Notes",
      "showCountInBar": true,
      "count": 0
    }
  }
}
