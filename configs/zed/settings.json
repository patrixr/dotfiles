{
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "pi-acp": {
      "type": "registry"
    }
  },
  "git_panel": {
    "dock": "left"
  },
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "left"
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Soft Charmed Icons",
    "dark": "Zed (Default)"
  },
  "diff_view_style": "unified",
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        }
      },
      "enable_lsp_tasks": true
    }
  },
  "rounded_selection": false,
  "context_servers": {
    "postgres-context-server": {
      "enabled": true,
      "remote": false,
      "settings": {
        "database_url": "postgresql://postgres:postgres@localhost:5432/t4b"
      }
    }
  },
  "ui_font_size": 15,
  "buffer_font_size": 13,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Aura Dark (Soft Text)"
  },
  "ssh_connections": [
    {
      "host": "139.59.109.77",
      "username": "root",
      "nickname": "Rhys' server",
      "projects": [
        {
          "paths": [
            "/etc/nginx"
          ]
        }
      ]
    }
  ],
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "profiles": {
      "write": {
        "default_model": {
          "provider": "copilot_chat",
          "model": "claude-sonnet-4.6",
          "enable_thinking": true,
          "effort": "high"
        },
        "name": "Write",
        "tools": {},
        "enable_all_context_servers": false,
        "context_servers": {}
      },
      "custom": {
        "name": "Custom",
        "tools": {},
        "enable_all_context_servers": false,
        "context_servers": {}
      }
    },
    "tool_permissions": {
      "tools": {
        "delete_path": {
          "always_allow": [
            {
              "pattern": "^project\\-samantha/packages/training/"
            },
            {
              "pattern": "^packages/training/src/cli/lib/"
            }
          ]
        },
        "terminal": {
          "default": "allow",
          "always_allow": [
            {
              "pattern": "^cat\\s+/home/patrick/Code/matchmaking/13_DECISIONS_AND_LESSONS\\.md(\\s|$)"
            },
            {
              "pattern": "^tail\\b"
            }
          ]
        },
        "create_directory": {
          "default": "allow",
          "always_allow": [
            {
              "pattern": "^uniplan\\-databoards/"
            },
            {
              "pattern": "^uniplan\\-databoards/databoards/"
            }
          ]
        },
        "fetch": {
          "default": "allow"
        },
        "save_file": {
          "default": "allow"
        },
        "move_path": {
          "default": "allow"
        }
      }
    },
    "default_profile": "write",
    "inline_assistant_model": {
      "provider": "mistral",
      "model": "codestral-latest"
    },
    "default_model": {
      "enable_thinking": false,
      "provider": "Z.ai",
      "model": "glm-5.1"
    }
  },
  "outline_panel": {
    "dock": "right"
  },
  "cursor_shape": "block",
  "current_line_highlight": "all",
  "edit_predictions": {
    "provider": "copilot",
    "mode": "subtle"
  },
  "tab_size": 2,
  "tab_bar": {
    "show": false,
    "show_nav_history_buttons": false
  },
  "terminal": {
    "toolbar": {
      "breadcrumbs": true
    },
    "shell": {
      "program": "nu"
    },
    "font_size": 13,
    "dock": "right",
    "scrollbar": {
      "show": "system"
    }
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
    "background_coloring": "disabled",
    "active_line_width": 2
  },
  "scrollbar": {
    "show": "auto",
    "cursors": true,
    "git_diff": true,
    "search_results": true,
    "selected_text": true,
    "selected_symbol": true,
    "diagnostics": "all",
    "axes": {
      "horizontal": false,
      "vertical": true
    }
  },
  "format_on_save": "on",
  "code_actions_on_format": {
    "source.fixAll.eslint": true,
    "source.removeUnusedImports": true,
    "source.organizeImports": true
  },
  "languages": {
    "Nu": {
      "tab_size": 2
    },
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "npx",
          "arguments": [
            "--yes",
            "prettier",
            "--stdin-filepath",
            "{buffer_path}"
          ]
        }
      },
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "format_on_save": "on"
    },
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "npx",
          "arguments": [
            "--yes",
            "prettier",
            "--stdin-filepath",
            "{buffer_path}"
          ]
        }
      },
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "format_on_save": "on"
    },
    "TSX": {
      "formatter": {
        "external": {
          "command": "npx",
          "arguments": [
            "--yes",
            "prettier",
            "--stdin-filepath",
            "{buffer_path}"
          ]
        }
      },
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "format_on_save": "on"
    }
  },
  "language_models": {
    "ollama": {
      "api_url": "https://hkbu-ai.tronica.io"
    },
    "openai_compatible": {
      "Z.ai": {
        "api_url": "https://api.z.ai/api/coding/paas/v4",
        "available_models": [
          {
            "name": "glm-5.1",
            "display_name": "GLM-5.1",
            "max_tokens": 200000,
            "max_output_tokens": 128000,
            "max_completion_tokens": 128000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": true,
              "prompt_cache_key": true
            }
          }
        ]
      }
    }
  }
}