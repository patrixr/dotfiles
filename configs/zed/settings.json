{
  "icon_theme": {
    "mode": "light",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "diff_view_style": "unified",
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        }
      },
      "enable_lsp_tasks": true
    }
  },
  "rounded_selection": false,
  "context_servers": {
    "postgres-context-server": {
      "enabled": true,
      "remote": false,
      "settings": {
        "database_url": "postgresql://postgres:postgres@localhost:5432/t4b"
      }
    }
  },
  "ui_font_size": 15,
  "buffer_font_size": 13,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "1984 Fancy"
  },
  "ssh_connections": [
    {
      "host": "139.59.109.77",
      "username": "root",
      "nickname": "Rhys' server",
      "projects": [
        {
          "paths": [
            "/etc/nginx"
          ]
        }
      ]
    }
  ],
  "agent": {
    "profiles": {
      "write": {
        "default_model": {
          "provider": "copilot_chat",
          "model": "claude-sonnet-4.6",
          "enable_thinking": true,
          "effort": "high"
        },
        "name": "Write",
        "tools": {},
        "enable_all_context_servers": false,
        "context_servers": {}
      },
      "custom": {
        "name": "Custom",
        "tools": {},
        "enable_all_context_servers": false,
        "context_servers": {}
      }
    },
    "tool_permissions": {
      "tools": {
        "create_directory": {
          "always_allow": [
            {
              "pattern": "^uniplan\\-databoards/"
            },
            {
              "pattern": "^uniplan\\-databoards/databoards/"
            }
          ]
        },
        "fetch": {
          "default": "allow"
        },
        "save_file": {
          "default": "allow"
        },
        "move_path": {
          "default": "allow"
        }
      }
    },
    "default_profile": "write",
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6"
    },
    "default_model": {
      "effort": "medium",
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6"
    }
  },
  "outline_panel": {
    "dock": "right"
  },
  "cursor_shape": "block",
  "current_line_highlight": "all",
  "edit_predictions": {
    "provider": "copilot",
    "mode": "subtle"
  },
  "tab_size": 2,
  "tab_bar": {
    "show": false,
    "show_nav_history_buttons": false
  },
  "terminal": {
    "toolbar": {
      "breadcrumbs": true
    },
    "shell": {
      "program": "nu"
    },
    "font_size": 13,
    "dock": "right",
    "scrollbar": {
      "show": "system"
    }
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
    "background_coloring": "disabled",
    "active_line_width": 2
  },
  "scrollbar": {
    "show": "auto",
    "cursors": true,
    "git_diff": true,
    "search_results": true,
    "selected_text": true,
    "selected_symbol": true,
    "diagnostics": "all",
    "axes": {
      "horizontal": false,
      "vertical": true
    }
  },
  "format_on_save": "on",
  "code_actions_on_format": {
    "source.fixAll.eslint": true,
    "source.removeUnusedImports": true,
    "source.organizeImports": true
  },
  "languages": {
    "Nu": {
      "tab_size": 2
    },
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "npx",
          "arguments": [
            "--yes",
            "prettier",
            "--stdin-filepath",
            "{buffer_path}"
          ]
        }
      },
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "format_on_save": "on"
    },
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "npx",
          "arguments": [
            "--yes",
            "prettier",
            "--stdin-filepath",
            "{buffer_path}"
          ]
        }
      },
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "format_on_save": "on"
    },
    "TSX": {
      "formatter": {
        "external": {
          "command": "npx",
          "arguments": [
            "--yes",
            "prettier",
            "--stdin-filepath",
            "{buffer_path}"
          ]
        }
      },
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      },
      "format_on_save": "on"
    }
  }
}